# Fluc - Controle Financeiro Pessoal
# Este aplicativo funciona 100% offline e local no navegador (usando LocalStorage).
# Não são necessárias chaves de API, banco de dados externo ou integrações de terceiros por padrão.

# Configuração Opcional de Sincronização em Nuvem (Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
